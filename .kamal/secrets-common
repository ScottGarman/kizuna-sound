# Secrets loaded by Kamal for ALL destinations (the plain .kamal/secrets is only used
# for non-destination deploys, so destination deploys need this file).
#
# Values reference local commands/files, so this is safe to commit (NO raw credentials
# here). The GHCR pull credential comes from the gh CLI; grant it package read access once:
#   gh auth refresh -h github.com -s read:packages

# GHCR pull credential, read from the gh CLI's authenticated token.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Rails master key, read from the local config/master.key (never commit that file).
RAILS_MASTER_KEY=$(cat config/master.key)
