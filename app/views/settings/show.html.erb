<% content_for :title, "Settings" %>

<div class="w-full max-w-lg">
  <h1 class="text-2xl font-semibold mb-6">Settings</h1>

  <%= form_with model: @setting, url: settings_path, method: :patch, class: "space-y-4" do |form| %>
    <% if @setting.errors.any? %>
      <div class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-800">
        <p class="font-medium"><%= pluralize(@setting.errors.count, "error") %> prevented these settings from being saved:</p>
        <ul class="mt-1 list-disc list-inside">
          <% @setting.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, "Site title", class: "block text-sm font-medium mb-1" %>
      <%= form.text_field :title, placeholder: "Sounds",
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
      <p class="mt-1 text-xs text-gray-500">
        Shown as the heading on your main feed. Leave blank to use the default (“Sounds”).
      </p>
    </div>

    <div>
      <%= form.label :about, "About", class: "block text-sm font-medium mb-1" %>
      <%= form.text_area :about, rows: 5,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
      <p class="mt-1 text-xs text-gray-500">
        A short description shown on your main feed, below the title. Line breaks are preserved.
      </p>
    </div>

    <div class="flex items-center gap-3">
      <%= form.submit "Save settings",
            class: "rounded-md bg-indigo-600 px-4 py-2 text-white font-medium hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Cancel", root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>
