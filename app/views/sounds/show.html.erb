<% content_for :title, @sound.title %>

<div class="w-full max-w-2xl">
  <div class="mb-2 flex items-center justify-between gap-4">
    <h1 class="text-2xl font-semibold"><%= @sound.title %></h1>

    <% if logged_in? %>
      <div class="flex shrink-0 items-center gap-4 text-sm">
        <%= link_to "Edit", edit_sound_path(@sound),
              class: "text-indigo-600 hover:text-indigo-800" %>
        <%= button_to "Delete", sound_path(@sound), method: :delete,
              form: { data: { turbo_confirm: "Delete “#{@sound.title}”?" } },
              class: "text-red-600 hover:text-red-800 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <p class="mb-4 text-sm text-gray-500">
    Uploaded <%= @sound.created_at.strftime("%B %-d, %Y") %>
  </p>

  <%= render "player", sound: @sound %>

  <p class="mt-6">
    <%= link_to "← Back to all sounds", root_path,
          class: "text-sm text-indigo-600 hover:text-indigo-800" %>
  </p>
</div>
