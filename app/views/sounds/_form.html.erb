<%= form_with model: sound, class: "space-y-4" do |form| %>
  <% if sound.errors.any? %>
    <div class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-800">
      <p class="font-medium"><%= pluralize(sound.errors.count, "error") %> prevented this from being saved:</p>
      <ul class="mt-1 list-disc list-inside">
        <% sound.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium mb-1" %>
    <%= form.text_field :title, autofocus: true,
          class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium mb-1" %>
    <%= form.text_area :description, rows: 4,
          class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-500">Optional. A few sentences describing this sound.</p>
  </div>

  <div>
    <%= form.label :audio, "Audio file", class: "block text-sm font-medium mb-1" %>
    <%= form.file_field :audio, accept: "audio/wav,audio/mpeg,audio/flac,.wav,.mp3,.flac",
          class: "block w-full text-sm text-gray-700 file:mr-4 file:rounded-md file:border-0 file:bg-indigo-50 file:px-4 file:py-2 file:text-indigo-700 hover:file:bg-indigo-100" %>
    <% if sound.audio.attached? %>
      <p class="mt-1 text-xs text-gray-500">
        Current file: <span class="font-medium"><%= sound.audio.filename %></span>.
        Choose a new file to replace it, or leave blank to keep it.
      </p>
    <% else %>
      <p class="mt-1 text-xs text-gray-500">Accepted formats: .wav, .mp3, .flac</p>
    <% end %>
  </div>

  <% if site_settings.tags_enabled? %>
  <div>
    <span class="block text-sm font-medium mb-1">Tags</span>

    <% if all_tags.any? %>
      <div class="flex flex-wrap gap-x-4 gap-y-2 rounded-md border border-gray-200 px-3 py-2">
        <% all_tags.each do |tag| %>
          <label class="flex items-center gap-1.5 text-sm">
            <%= form.check_box :tag_ids, { multiple: true, checked: sound.tag_ids.include?(tag.id) }, tag.id, nil %>
            <%= tag.name %>
          </label>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-500">No tags yet — add the first ones below.</p>
    <% end %>

    <%= form.label :new_tag_names, "Add new tags", class: "mt-3 block text-sm font-medium mb-1" %>
    <%= form.text_field :new_tag_names, value: "", placeholder: "e.g. ambient, field recording, rain",
          class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-500">Separate multiple tags with commas.</p>
  </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= form.submit submit_label,
          class: "rounded-md bg-indigo-600 px-4 py-2 text-white font-medium hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
