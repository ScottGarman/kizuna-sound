<% content_for :title, "Kizuna Sound" %>

<h1 class="text-2xl font-semibold mb-6">Sounds</h1>

<% if @tags.any? %>
  <div class="mb-6 rounded-md border border-gray-200 bg-white px-4 py-3">
    <p class="mb-2 text-sm font-medium text-gray-700">Browse by tag</p>
    <div class="flex flex-wrap gap-2">
      <% @tags.each do |tag| %>
        <%= link_to root_path(tag: tag.name),
              class: "rounded-full border px-3 py-1 text-sm #{@active_tag&.id == tag.id ? "border-indigo-600 bg-indigo-600 text-white" : "border-gray-300 text-gray-700 hover:bg-gray-100"}" do %>
          <%= tag.name %> <span class="text-xs opacity-75">(<%= tag.sounds_count %>)</span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @active_tag %>
  <p class="mb-4 flex items-center gap-2 text-sm text-gray-600">
    Showing sounds tagged <span class="font-medium">“<%= @active_tag.name %>”</span>
    <%= link_to "Clear filter", root_path, class: "text-indigo-600 hover:text-indigo-800" %>
  </p>
<% end %>

<% if @sounds.any? %>
  <ul class="divide-y divide-gray-200 rounded-md border border-gray-200 bg-white">
    <% @sounds.each do |sound| %>
      <li class="px-4 py-3">
        <div class="flex items-center justify-between gap-4">
          <div>
            <%= link_to sound.title, sound_path(sound),
                  class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
            <p class="text-xs text-gray-500">
              Uploaded <%= sound.created_at.strftime("%B %-d, %Y") %>
            </p>
          </div>

          <% if logged_in? %>
            <div class="flex shrink-0 items-center gap-4">
              <%= link_to "Edit", edit_sound_path(sound),
                    class: "text-sm text-indigo-600 hover:text-indigo-800" %>
              <%= button_to "Delete", sound_path(sound), method: :delete,
                    form: { data: { turbo_confirm: "Delete “#{sound.title}”?" } },
                    class: "text-sm text-red-600 hover:text-red-800 cursor-pointer" %>
            </div>
          <% end %>
        </div>

        <div class="mt-3">
          <%= render "player", sound: sound %>
        </div>
      </li>
    <% end %>
  </ul>
<% elsif @active_tag %>
  <p class="text-gray-500">No sounds tagged “<%= @active_tag.name %>”.</p>
<% else %>
  <p class="text-gray-500">
    No sounds yet.
    <% if logged_in? %>
      <%= link_to "Upload the first one", new_sound_path, class: "text-indigo-600 hover:text-indigo-800" %>.
    <% end %>
  </p>
<% end %>
