<%# Locals: page (a Kaminari::Helpers::Page) %>
<li>
  <% if page.current? %>
    <span aria-current="page"
          class="inline-flex min-w-9 justify-center rounded-md border border-indigo-600 bg-indigo-600 px-3 py-1.5 font-medium text-white">
      <%= page %>
    </span>
  <% else %>
    <%= link_to page, url, rel: page.rel,
          class: "inline-flex min-w-9 justify-center rounded-md border border-gray-300 px-3 py-1.5 text-gray-700 hover:bg-gray-100" %>
  <% end %>
</li>
